{
  "preprocessing_steps": [
    {
      "step": "imputer",
      "name": "SimpleImputer",
      "module": "sklearn.impute.SimpleImputer",
      "hyperparameters": {
        "strategy": {
          "type": "categorical",
          "search_space": ["mean", "most_frequent", "constant"]
        },
        "fill_value": {
          "type": "categorical",
          "search_space": [0, -1, "missing"],
          "note": "Only when strategy='constant'"
        }
      }
    },
    {
      "step": "imputer",
      "name": "KNNImputer",
      "module": "sklearn.impute.KNNImputer",
      "hyperparameters": {
        "n_neighbors": {
          "type": "integer",
          "search_space": [2, 10],
          "suggested_values": [2, 5, 7, 10]
        },
        "weights": {
          "type": "categorical",
          "search_space": ["uniform", "distance"]
        }
      }
    },
    {
      "step": "scaler",
      "name": "StandardScaler",
      "module": "sklearn.preprocessing.StandardScaler",
      "hyperparameters": {
        "with_mean": {
          "type": "categorical",
          "search_space": [true, false]
        },
        "with_std": {
          "type": "categorical",
          "search_space": [true, false]
        }
      }
    },
    {
      "step": "scaler",
      "name": "MinMaxScaler",
      "module": "sklearn.preprocessing.MinMaxScaler",
      "hyperparameters": {
        "feature_range": {
          "type": "tuple",
          "search_space": [[0, 1], [-1, 1], [0, 2]]
        }
      }
    },
    {
      "step": "scaler",
      "name": "RobustScaler",
      "module": "sklearn.preprocessing.RobustScaler",
      "hyperparameters": {
        "with_centering": {
          "type": "categorical",
          "search_space": [true, false]
        },
        "with_scaling": {
          "type": "categorical",
          "search_space": [true, false]
        },
        "quantile_range": {
          "type": "categorical",
          "search_space": [[25, 75], [10, 90], [5, 95]]
        }
      }
    },
    {
      "step": "scaler",
      "name": "MaxAbsScaler",
      "module": "sklearn.preprocessing.MaxAbsScaler",
      "hyperparameters": {}
    },
    {
      "step": "scaler",
      "name": "Normalizer",
      "module": "sklearn.preprocessing.Normalizer",
      "hyperparameters": {
        "norm": {
          "type": "categorical",
          "search_space": ["l1", "l2", "max"]
        }
      }
    },
    {
      "step": "encoder",
      "name": "OneHotEncoder",
      "module": "sklearn.preprocessing.OneHotEncoder",
      "hyperparameters": {
        "drop": {
          "type": "categorical",
          "search_space": [null, "first", "if_binary"]
        },
        "handle_unknown": {
          "type": "categorical",
          "search_space": ["error", "ignore", "infrequent_if_exist"]
        },
        "sparse_output": {
          "type": "categorical",
          "search_space": [true, false]
        }
      }
    },
    {
      "step": "encoder",
      "name": "OrdinalEncoder",
      "module": "sklearn.preprocessing.OrdinalEncoder",
      "hyperparameters": {
        "handle_unknown": {
          "type": "categorical",
          "search_space": ["error", "use_encoded_value"]
        },
        "unknown_value": {
          "type": "categorical",
          "search_space": [null, -1],
          "note": "Only when handle_unknown='use_encoded_value'"
        }
      }
    },
    {
      "step": "transformer",
      "name": "PowerTransformer",
      "module": "sklearn.preprocessing.PowerTransformer",
      "hyperparameters": {
        "method": {
          "type": "categorical",
          "search_space": ["yeo-johnson", "box-cox"]
        },
        "standardize": {
          "type": "categorical",
          "search_space": [true, false]
        }
      }
    },
    {
      "step": "transformer",
      "name": "QuantileTransformer",
      "module": "sklearn.preprocessing.QuantileTransformer",
      "hyperparameters": {
        "n_quantiles": {
          "type": "integer",
          "search_space": [100, 2000],
          "suggested_values": [100, 500, 1000]
        },
        "output_distribution": {
          "type": "categorical",
          "search_space": ["uniform", "normal"]
        }
      }
    },
    {
      "step": "transformer",
      "name": "PolynomialFeatures",
      "module": "sklearn.preprocessing.PolynomialFeatures",
      "hyperparameters": {
        "degree": {
          "type": "integer",
          "search_space": [2, 4],
          "suggested_values": [2, 3]
        },
        "interaction_only": {
          "type": "categorical",
          "search_space": [true, false]
        },
        "include_bias": {
          "type": "categorical",
          "search_space": [true, false]
        }
      }
    },
    {
      "step": "feature_selection",
      "name": "SelectKBest",
      "module": "sklearn.feature_selection.SelectKBest",
      "hyperparameters": {
        "k": {
          "type": "integer",
          "search_space": [5, 50],
          "suggested_values": [5, 10, 15, 20, 30]
        }
      }
    },
    {
      "step": "feature_selection",
      "name": "SelectPercentile",
      "module": "sklearn.feature_selection.SelectPercentile",
      "hyperparameters": {
        "percentile": {
          "type": "integer",
          "search_space": [10, 100],
          "suggested_values": [25, 50, 75, 100]
        }
      }
    },
    {
      "step": "feature_selection",
      "name": "VarianceThreshold",
      "module": "sklearn.feature_selection.VarianceThreshold",
      "hyperparameters": {
        "threshold": {
          "type": "continuous",
          "search_space": [0.0, 1.0],
          "suggested_values": [0.0, 0.01, 0.05, 0.1]
        }
      }
    },
    {
      "step": "dimensionality_reduction",
      "name": "PCA",
      "module": "sklearn.decomposition.PCA",
      "hyperparameters": {
        "n_components": {
          "type": "categorical",
          "search_space": [5, 10, 15, 20, 30, 50, null, 0.95, 0.99]
        },
        "whiten": {
          "type": "categorical",
          "search_space": [true, false]
        },
        "svd_solver": {
          "type": "categorical",
          "search_space": ["auto", "full", "arpack", "randomized"]
        }
      }
    },
    {
      "step": "dimensionality_reduction",
      "name": "TruncatedSVD",
      "module": "sklearn.decomposition.TruncatedSVD",
      "hyperparameters": {
        "n_components": {
          "type": "integer",
          "search_space": [2, 100],
          "suggested_values": [5, 10, 20, 50]
        },
        "n_iter": {
          "type": "integer",
          "search_space": [3, 10],
          "suggested_values": [5, 7]
        }
      }
    },
    {
      "step": "dimensionality_reduction",
      "name": "NMF",
      "module": "sklearn.decomposition.NMF",
      "hyperparameters": {
        "n_components": {
          "type": "integer",
          "search_space": [2, 50],
          "suggested_values": [5, 10, 20]
        },
        "init": {
          "type": "categorical",
          "search_space": ["random", "nndsvd", "nndsvda", "nndsvdar"]
        },
        "max_iter": {
          "type": "integer",
          "search_space": [100, 1000],
          "suggested_values": [200, 500]
        }
      }
    },
    {
      "step": "column_transformer",
      "name": "ColumnTransformer",
      "module": "sklearn.compose.ColumnTransformer",
      "hyperparameters": {
        "transformers": {
          "type": "list",
          "schema": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "transformer": {
                  "anyOf": [
                    { "type": "string" },
                    {
                      "type": "object",
                      "properties": {
                        "steps": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "class": { "type": "string" },
                              "params": { "type": "object" }
                            },
                            "required": ["class"]
                          }
                        }
                      },
                      "required": ["steps"]
                    },
                    { "enum": ["passthrough", "drop", null] }
                  ]
                },
                "columns": {
                  "type": "array",
                  "items": {
                    "anyOf": [{ "type": "string" }, { "type": "integer" }]
                  }
                }
              },
              "required": ["name", "transformer", "columns"]
            }
          },
          "example": [
            {
              "name": "num",
              "transformer": {
                "steps": [
                  { "class": "SimpleImputer", "params": { "strategy": "mean" } },
                  {
                    "class": "StandardScaler",
                    "params": { "with_mean": true, "with_std": true }
                  }
                ]
              },
              "columns": ["column_0", "column_1"]
            },
            {
              "name": "cat",
              "transformer": {
                "steps": [
                  {
                    "class": "SimpleImputer",
                    "params": { "strategy": "most_frequent" }
                  },
                  {
                    "class": "OneHotEncoder",
                    "params": { "handle_unknown": "ignore", "sparse_output": false }
                  }
                ]
              },
              "columns": ["column_2"]
            }
          ]
        },
        "remainder": {
          "type": "categorical",
          "search_space": ["drop", "passthrough", null]
        }
      }
    }
  ],
  "sklearn_classification_algorithms": [
